# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # development | production | test

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DB_URI=mongodb://localhost:27017/qcommerce   # MongoDB connection URI
DB_RETRY_ATTEMPTS=5            # Number of reconnect attempts
DB_RETRY_DELAY_MS=3000         # Milliseconds between attempts

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED: minimum 64 characters each (use: openssl rand -hex 64)
JWT_ACCESS_SECRET=replace_with_minimum_64_char_random_secret_access_key_here_1234567890
JWT_REFRESH_SECRET=replace_with_minimum_64_char_random_secret_refresh_key_here_1234567890
JWT_ACCESS_TTL_SECONDS=900     # 15 minutes
JWT_REFRESH_TTL_SECONDS=604800 # 7 days

# ─── SECURITY ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12               # Min 10. Higher = slower hash = more secure
CLIENT_URL=http://localhost:3000

# ─── REDIS (optional — leave blank to use in-memory fallbacks) ─────────────────
# REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=qc:

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10         # Max auth requests per window per IP
RATE_LIMIT_AUTH_WINDOW=900000  # 15 minutes in ms
RATE_LIMIT_GENERAL_MAX=100     # Max general API requests per window
RATE_LIMIT_GENERAL_WINDOW=60000 # 1 minute in ms

# ─── OBSERVABILITY ────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # fatal | error | warn | info | debug
METRICS_ENABLED=false          # true = expose /metrics endpoint

# ─── RAZORPAY ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
