# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# When running via docker-compose, use the service name as host
# Include credentials if MongoDB auth is enabled (required in production)
DB_URI=mongodb://admin:password@mongodb:27017/quickcommerce?authSource=admin
DB_RETRY_ATTEMPTS=5                    # How many times to retry MongoDB connection on startup
DB_RETRY_DELAY_MS=3000                 # Milliseconds between retry attempts

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=                     # Required — minimum 64 characters
JWT_REFRESH_SECRET=                    # Required — minimum 64 characters
JWT_ACCESS_TTL_SECONDS=900             # Access token lifetime in seconds (default: 15 min)
JWT_REFRESH_TTL_SECONDS=604800         # Refresh token lifetime in seconds (default: 7 days)

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12                       # Minimum 10 — higher = slower hash = more secure

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost

# ─── Redis (optional — leave blank to use in-memory fallbacks) ────────────────
# Redis is now ENABLED by default for Socket.io horizontal scaling
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=qc:                   # Namespace prefix for all Redis keys

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=100                # Max auth requests per window per IP
RATE_LIMIT_AUTH_WINDOW=900000          # 15 minutes in ms
RATE_LIMIT_GENERAL_MAX=1000            # Max general API requests per window per IP
RATE_LIMIT_GENERAL_WINDOW=60000        # 1 minute in ms

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=info                         # fatal | error | warn | info | debug
METRICS_ENABLED=false                  # Set true to enable Prometheus-style metrics

# ─── Frontend (used by Next.js — must be NEXT_PUBLIC_ prefix) ─────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_SOCKET_URL=http://localhost
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
NEXT_PUBLIC_OPENCAGE_API_KEY=       # OpenCage Geocoding API (2,500 free requests/day) - Get from: https://opencagedata.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=       # Optional: Google Maps Geocoding API (fallback) - Get from: https://console.cloud.google.com/google/maps-apis

# ─── MongoDB auth (used by docker-compose mongodb service) ────────────────────
MONGO_ROOT_USERNAME=admin              # Required — MongoDB will not start without this
MONGO_ROOT_PASSWORD=                   # Required — set a strong password
