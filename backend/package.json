{
  "name": "qcommerce-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Real-Time Quick Commerce Backend — Express + Socket.io + MongoDB",
  "scripts": {
    "dev": "nodemon --exec \"tsx --env-file=.env.development src/server.ts\"",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:pm2": "npm run build && pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop eeshuu-backend",
    "restart:pm2": "npm run build && pm2 restart eeshuu-backend",
    "logs:pm2": "pm2 logs eeshuu-backend",
    "seed": "tsx --env-file=.env.development scripts/seed-demo-data.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.4",
    "pino": "^9.1.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.1.0",
    "razorpay": "^2.9.6",
    "redis": "^4.6.13",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^1.6.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
